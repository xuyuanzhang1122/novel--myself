{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@xu-novel/ui/*": ["packages/ui/src/*"],
      "@xu-novel/ui": ["packages/ui/src/index.ts"],
      "@xu-novel/lib/*": ["packages/lib/src/*"],
      "@xu-novel/lib": ["packages/lib/src/index.ts"]
    }
  }
}
