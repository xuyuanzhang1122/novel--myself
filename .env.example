# Built-in admin login
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=novel123456

# Local app URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Admin -> site cache revalidation
SITE_REVALIDATE_URL=http://localhost:3000/api/revalidate
SITE_REVALIDATE_SECRET=replace-with-a-random-secret

# Image storage service
IMAGE_API_BASE_URL=https://image.xumy.art
IMAGE_API_KEY=
IMAGE_API_BEARER_TOKEN=

# Optional session signing secret. If omitted, SITE_REVALIDATE_SECRET is reused.
AUTH_SESSION_SECRET=

# Optional. Force auth cookies to be Secure on HTTPS, or disable it on plain HTTP.
AUTH_COOKIE_SECURE=

# Leave empty for localhost. Set to .yourdomain.com when sharing auth cookies in production.
NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=
