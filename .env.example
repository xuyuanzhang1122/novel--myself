# Supabase project URL (required)
NEXT_PUBLIC_SUPABASE_URL=
# Supabase anon public key (required)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase service role key, server only (required for admin writes and imports)
SUPABASE_SERVICE_ROLE_KEY=
# Leave empty for localhost, use .xu-novel.com in production
NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=
# Public reading site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Admin workspace URL
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
# Revalidate endpoint on the site app
SITE_REVALIDATE_URL=http://localhost:3000/api/revalidate
# Shared secret for admin -> site revalidation
SITE_REVALIDATE_SECRET=
# Admin email used for login
ADMIN_EMAIL=
# Optional. If omitted, the app falls back to novel123456 in local development.
ADMIN_PASSWORD=
# Optional. If omitted, the app falls back to SITE_REVALIDATE_SECRET for session signing.
AUTH_SESSION_SECRET=
